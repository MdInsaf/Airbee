# AWS Cognito (from Cognito Console → User Pool)
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# API base URL.
# Leave blank to use same-origin /api, /ai, and /public routes behind CloudFront.
# Use a full URL for direct API Gateway or Lambda URL access.
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# Hosting mode:
# - unified: single app handles platform + booking by host
# - platform: platform/admin app only
# - booking: booking frontend only
VITE_APP_HOSTING_MODE=unified

# Optional: comma-separated platform hosts that should keep rendering the AIR BEE marketing site
VITE_PLATFORM_HOSTS=app.airbee.com

# Optional: base domain used to build tenant subdomain preview URLs in settings
VITE_PUBLIC_BASE_DOMAIN=airbee.com
